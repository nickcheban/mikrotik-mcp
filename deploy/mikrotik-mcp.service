[Unit]
Description=MikroTik MCP Server
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/mikrotik-mcp
EnvironmentFile=/opt/mikrotik-mcp/.env
ExecStart=/opt/mikrotik-mcp/venv/bin/uvicorn server:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
