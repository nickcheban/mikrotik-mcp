# Адрес и порт RouterOS API (порт 8728 — незашифрованный API, стандартный для RouterOS)
MIKROTIK_HOST=192.168.1.1
MIKROTIK_PORT=8728

# Создайте отдельного пользователя с ограниченными правами (read-only группа) —
# не используйте основной admin-аккаунт.
MIKROTIK_USER=ai-mcp
MIKROTIK_PASS=

# Bearer-токен для авторизации запросов к этому MCP-серверу.
# Сгенерируйте случайную строку, например: python3 -c "import secrets; print(secrets.token_hex(32))"
# Если оставить пустым — сервер будет отвечать без авторизации (только для локальной сети/VPN!).
MCP_SECRET=

# Домен, на котором сервер доступен снаружи (нужен только для /.well-known/oauth-authorization-server,
# см. README — Security model)
DOMAIN=mikrotik-mcp.example.com
