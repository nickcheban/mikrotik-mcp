# RouterOS API address and port (8728 is the unencrypted API, RouterOS default)
MIKROTIK_HOST=192.168.1.1
MIKROTIK_PORT=8728

# Create a dedicated user in a read-only group — don't use the main admin account.
MIKROTIK_USER=ai-mcp
MIKROTIK_PASS=

# Bearer token used to authorize requests to this MCP server.
# Generate a random string, e.g.: python3 -c "import secrets; print(secrets.token_hex(32))"
# If left empty, the server responds without checking auth (local network/VPN only!).
MCP_SECRET=

# Domain this server is reachable at externally (only needed for
# /.well-known/oauth-authorization-server, see README — Security model)
DOMAIN=mikrotik-mcp.example.com
